{
  "keep_routes": [
    {
      "route_id": "5",
      "route_short_name": "5",
      "route_comment": "Light-rail != Streetcars (shown w/ subway on official web site)"
    },
    {
      "route_id": "6",
      "route_short_name": "6",
      "route_comment": "Light-rail != Streetcars (shown w/ subway on official web site)"
    }
  ],
  "default_route_id_enabled": true,
  "use_route_short_name_for_route_id": true,
  "default_route_long_name_enabled": true,
  "route_long_name_cleaners": [
    {
      "regex": "line \\d+ (\\()?([^\\)]+)(\\))?$",
      "ignore_case": true,
      "replacement": "$2"
    }
  ],
  "route_colors_ignored": [
    "D5C82B",
    "008000",
    "B300B3"
  ],
  "route_colors": [
    {
      "route_short_name": "1",
      "color": "FFC72C",
      "color_comment": "YELLOW"
    },
    {
      "route_short_name": "2",
      "color": "009A44",
      "color_comment": "GREEN"
    },
    {
      "route_short_name": "3",
      "color": "0086D6",
      "color_comment": "BLUE"
    },
    {
      "route_short_name": "4",
      "color": "A20067",
      "color_comment": "PURPLE"
    },
    {
      "route_short_name": "5",
      "color": "FE5000",
      "color_comment": "ORANGE"
    }
  ],
  "direction_finder_enabled": true,
  "stop_time_excludes": [
    {
      "stop_time_headsign_regex": "(not in service)",
      "ignore_case": true
    }
  ],
  "stop_name_cleaners": [
    {
      "regex": "(\\s+-\\s+eastbound(\\s+platform)?(\\s+|$))",
      "ignore_case": true,
      "replacement": " EB$3"
    },
    {
      "regex": "(\\s+-\\s+westbound(\\s+platform)?(\\s+|$))",
      "ignore_case": true,
      "replacement": " WB$3"
    },
    {
      "regex": "(\\s+-\\s+southbound(\\s+platform)?(\\s+|$))",
      "ignore_case": true,
      "replacement": " SB$3"
    },
    {
      "regex": "(\\s+-\\s+northbound(\\s+platform)?(\\s+|$))",
      "ignore_case": true,
      "replacement": " NB$3"
    },
    {
      "regex": "(\\s+platform$)",
      "ignore_case": true
    },
    {
      "regex": "(\\s+towards\\s+(.*)$)",
      "ignore_case": true,
      "replacement": " (to $2)"
    },
    {
      "regex": "subway",
      "is_word": true,
      "ignore_case": true
    }
  ]
}
